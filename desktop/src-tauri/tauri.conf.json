{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CHERENKOV",
  "version": "1.0.0",
  "identifier": "com.cherenkov.dev",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:8000",
    "frontendDist": "../../cherenkov/web/ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CHERENKOV",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "http://127.0.0.1:8000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["cherenkov-launcher"],
    "shortDescription": "AI-native API conformance test generator",
    "longDescription": "CHERENKOV reads your OpenAPI spec, generates typed Playwright tests using a local LLM, runs them against your real server, and catches spec-conformance drift. Zero lock-in.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": []
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": "",
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    },
    "linux": {
      "deb": { "depends": [] }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/moaidmoatasem/cherenkov-qa/releases/latest/download/latest.json"
      ]
    }
  }
}

  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moaidmoatasem/cherenkov-qa.git"
  },
  "license": "Apache-2.0",
  "author": "Moayed Badawy",
  "bin": {
    "cherenkov-mcp-server": "./index.js"
  },

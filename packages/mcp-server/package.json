{
  "name": "@cherenkov-qa/mcp-server",
  "version": "1.0.0",
  "description": "MCP server wrapper for CHERENKOV QA — exposes conformance, drift, HITL, and compliance tools over stdio.",
  "keywords": ["mcp", "api-testing", "conformance", "qa", "llm-tools"],
  "homepage": "https://github.com/moaidmoatasem/cherenkov-qa",
  "bugs": {
